---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { company } from "../data/company";
import { pageMeta, siteCopy } from "../data/translations";

const lang = "en";
const copy = siteCopy.en;
---

<BaseLayout title={pageMeta.en.contact.title} description={pageMeta.en.contact.description} lang={lang}>
  <section class="section-space">
    <div class="shell space-y-16">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.85fr] lg:items-end">
        <div class="space-y-6">
          <p class="eyebrow hero-entry">Contact</p>
          <h1 class="display-title hero-entry hero-entry-delay-1 max-w-4xl">Direct contact for manufacturing inquiries.</h1>
        </div>
        <p class="body-copy hero-entry hero-entry-delay-2 max-w-xl">{copy.forms.contactTitle}</p>
      </div>

      <div class="rule grid gap-12 pt-10 lg:grid-cols-[0.8fr_1.2fr]">
        <dl class="hero-entry hero-entry-delay-3 grid gap-7">
          <div class="grid gap-2 border-b border-black/10 pb-5 sm:grid-cols-[7rem_1fr]"><dt class="text-[0.7rem] uppercase tracking-[0.22em] text-[rgba(17,17,17,0.42)]">Company</dt><dd class="text-lg text-[#111111]">{company.nameEn}</dd></div>
          <div class="grid gap-2 border-b border-black/10 pb-5 sm:grid-cols-[7rem_1fr]"><dt class="text-[0.7rem] uppercase tracking-[0.22em] text-[rgba(17,17,17,0.42)]">Address</dt><dd class="text-lg text-[#111111]">{company.addressPlaceholder}</dd></div>
          <div class="grid gap-2 border-b border-black/10 pb-5 sm:grid-cols-[7rem_1fr]"><dt class="text-[0.7rem] uppercase tracking-[0.22em] text-[rgba(17,17,17,0.42)]">Phone</dt><dd class="text-lg text-[#111111]">{company.phonePlaceholder}</dd></div>
          <div class="grid gap-2 border-b border-black/10 pb-5 sm:grid-cols-[7rem_1fr]"><dt class="text-[0.7rem] uppercase tracking-[0.22em] text-[rgba(17,17,17,0.42)]">Email</dt><dd class="text-lg text-[#111111]">{company.emailPlaceholder}</dd></div>
          <div class="grid gap-2 border-b border-black/10 pb-5 sm:grid-cols-[7rem_1fr]"><dt class="text-[0.7rem] uppercase tracking-[0.22em] text-[rgba(17,17,17,0.42)]">EIK</dt><dd class="text-lg text-[#111111]">{company.eik}</dd></div>
          <div class="grid gap-2 border-b border-black/10 pb-5 sm:grid-cols-[7rem_1fr]"><dt class="text-[0.7rem] uppercase tracking-[0.22em] text-[rgba(17,17,17,0.42)]">VAT</dt><dd class="text-lg text-[#111111]">{company.vat}</dd></div>
        </dl>
        <div class="hero-entry hero-entry-delay-3 lg:pl-10">
          <ContactForm lang={lang} successPath="/contact-success" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
