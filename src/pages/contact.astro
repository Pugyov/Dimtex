---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import FactoryImage from "../components/FactoryImage.astro";
import { contactContent, factoryImages } from "../data/company";
import { pageMeta } from "../data/translations";

const lang = "en";
const content = contactContent.en;
const contactImage = {
  src: factoryImages.sewingDetail.src,
  fallbackSrc: factoryImages.sewingDetail.fallbackSrc,
  alt: factoryImages.sewingDetail.alt.en
};
---

<BaseLayout title={pageMeta.en.contact.title} description={pageMeta.en.contact.description} lang={lang}>
  <section class="profile-hero">
    <div class="shell profile-hero-grid">
      <div class="space-y-6">
        <p class="eyebrow hero-entry">{content.heroLabel}</p>
        <h1 class="profile-title hero-entry hero-entry-delay-1">{content.heroTitle}</h1>
      </div>
      <p class="profile-lede hero-entry hero-entry-delay-2">{content.heroIntro}</p>
    </div>
  </section>

  <section class="profile-section">
    <div class="shell profile-intro contact-profile">
      <aside class="contact-aside hero-entry hero-entry-delay-3">
        <FactoryImage image={contactImage} sizes="(min-width: 1024px) 42vw, 100vw" class="profile-photo contact-photo" />
        <p class="image-caption">{content.imageCaption}</p>
      </aside>

      <div class="profile-copy contact-form-wrap hero-entry hero-entry-delay-3">
        <div class="profile-section-heading contact-form-heading">
          <p class="eyebrow">{content.heroLabel}</p>
          <h2 class="profile-section-title">{content.formTitle}</h2>
          <p class="body-copy">{content.formIntro}</p>
        </div>
        <ContactForm lang={lang} successPath="/contact-success" />
      </div>
    </div>
  </section>
</BaseLayout>
