---
import BaseLayout from "../layouts/BaseLayout.astro";
import FactoryImage from "../components/FactoryImage.astro";
import { factoryImages, homeContent } from "../data/company";
import { pageMeta } from "../data/translations";

const lang = "en";
const content = homeContent.en;
const workshopImage = {
  src: factoryImages.workshop.src,
  fallbackSrc: factoryImages.workshop.fallbackSrc,
  alt: factoryImages.workshop.alt.en
};
const sewingImage = {
  src: factoryImages.sewingDetail.src,
  fallbackSrc: factoryImages.sewingDetail.fallbackSrc,
  alt: factoryImages.sewingDetail.alt.en
};
---

<BaseLayout title={pageMeta.en.home.title} description={pageMeta.en.home.description} lang={lang}>
  <section class="editorial-hero">
    <FactoryImage image={workshopImage} loading="eager" sizes="100vw" class="editorial-hero-media" />
    <div class="editorial-hero-shade" aria-hidden="true"></div>
    <div class="shell editorial-hero-content">
      <div class="max-w-4xl space-y-7">
        <p class="editorial-kicker hero-entry">{content.heroLabel}</p>
        <h1 class="editorial-heading hero-entry hero-entry-delay-1">{content.heroTitle}</h1>
        <p class="editorial-lede hero-entry hero-entry-delay-2 max-w-2xl">{content.heroIntro}</p>
        <div class="hero-entry hero-entry-delay-3 flex flex-wrap gap-3">
          <a href="/contact" class="button-primary">{content.primaryAction}</a>
          <a href="/about" class="button-secondary">{content.secondaryAction}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="shell process-layout">
      <div class="process-copy">
        <p class="eyebrow">{content.processLabel}</p>
        <h2 class="section-title">{content.processTitle}</h2>
        <p class="body-copy max-w-lg">{content.processIntro}</p>
      </div>
      <div class="process-media">
        <FactoryImage image={sewingImage} sizes="(min-width: 1024px) 50vw, 100vw" class="aspect-[4/5] w-full object-cover" />
      </div>
      <div class="process-steps">
        {content.processSteps.map((step) => (
          <div class="process-step">
            <p class="process-step-label">{step.label}</p>
            <p class="process-step-text">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-layout">
      <h2 class="section-title text-paper">{content.finalTitle}</h2>
      <div class="space-y-6">
        <p class="dark-copy">{content.finalBody}</p>
        <a href="/contact" class="button-primary button-on-dark">{content.finalAction}</a>
      </div>
    </div>
  </section>
</BaseLayout>
