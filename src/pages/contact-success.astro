---
import BaseLayout from "../layouts/BaseLayout.astro";

const lang = "en";
---

<BaseLayout title="Contact Request Sent | DIMTEX LTD" description="Confirmation page for contact form submission." lang={lang} noIndex>
  <section class="section-space">
    <div class="shell max-w-3xl space-y-6">
      <p class="eyebrow hero-entry">Thank you</p>
      <h1 class="display-title hero-entry hero-entry-delay-1">Your inquiry has been sent.</h1>
      <div class="rule hero-entry hero-entry-delay-2 pt-6 text-sm text-[#111111]">
        <a href="/contact" class="hero-action underline-offset-4 hover:underline">Back to Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
