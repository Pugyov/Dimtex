---
import BaseLayout from "../layouts/BaseLayout.astro";
import FactoryImage from "../components/FactoryImage.astro";
import { aboutContent, factoryImages } from "../data/company";
import { pageMeta } from "../data/translations";

const lang = "en";
const content = aboutContent.en;
const teamImage = {
  src: factoryImages.teamOrFamily.src,
  fallbackSrc: factoryImages.teamOrFamily.fallbackSrc,
  alt: factoryImages.teamOrFamily.alt.en
};
---

<BaseLayout title={pageMeta.en.about.title} description={pageMeta.en.about.description} lang={lang}>
  <section class="profile-hero">
    <div class="shell profile-hero-grid">
      <div class="space-y-6">
        <p class="eyebrow hero-entry">{content.heroLabel}</p>
        <h1 class="profile-title hero-entry hero-entry-delay-1">{content.heroTitle}</h1>
      </div>
      <p class="profile-lede hero-entry hero-entry-delay-2">{content.heroIntro}</p>
    </div>
  </section>

  <section class="profile-section">
    <div class="shell profile-intro">
      <div class="hero-entry hero-entry-delay-3">
        <FactoryImage image={teamImage} sizes="(min-width: 1024px) 42vw, 100vw" class="profile-photo" />
      </div>
      <div class="profile-copy hero-entry hero-entry-delay-3">
        <p class="eyebrow">{content.snapshots[0].label}</p>
        <h2 class="profile-section-title">{content.profileTitle}</h2>
        <div class="space-y-4">
          {content.profileParagraphs.map((paragraph) => (
            <p class="body-copy">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="profile-section profile-section-ruled">
    <div class="shell">
      <div class="profile-section-heading">
        <p class="eyebrow">{content.capabilitiesLabel}</p>
        <h2 class="profile-section-title">{content.snapshots[1].title}</h2>
      </div>
      <div class="profile-capabilities">
        {content.capabilities.map((item) => (
          <article class="profile-capability">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="closing-section">
    <div class="shell closing-cta">
      <h2 class="closing-title">{content.closingTitle}</h2>
      <a href="/contact" class="button-primary">{content.closingAction}</a>
    </div>
  </section>
</BaseLayout>
