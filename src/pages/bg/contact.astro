---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.astro";
import FactoryImage from "../../components/FactoryImage.astro";
import { company, contactContent, factoryImages } from "../../data/company";
import { pageMeta } from "../../data/translations";

const lang = "bg";
const content = contactContent.bg;
const contactImage = {
  src: factoryImages.sewingDetail.src,
  fallbackSrc: factoryImages.sewingDetail.fallbackSrc,
  alt: factoryImages.sewingDetail.alt.bg
};
const bannerImage = {
  src: factoryImages.workshop.src,
  fallbackSrc: factoryImages.workshop.fallbackSrc,
  alt: factoryImages.workshop.alt.bg
};
---

<BaseLayout title={pageMeta.bg.contact.title} description={pageMeta.bg.contact.description} lang={lang}>
  <section class="profile-hero">
    <FactoryImage image={bannerImage} loading="eager" sizes="100vw" class="page-banner-media" />
    <div class="page-banner-shade" aria-hidden="true"></div>
    <div class="shell profile-hero-grid">
      <div class="space-y-6">
        <p class="eyebrow hero-entry">{content.heroLabel}</p>
        <h1 class="profile-title hero-entry hero-entry-delay-1">{content.heroTitle}</h1>
      </div>
      <p class="profile-lede hero-entry hero-entry-delay-2">{content.heroIntro}</p>
    </div>
  </section>

  <section class="profile-section">
    <div class="shell profile-intro contact-profile">
      <aside class="contact-aside">
        <div class="contact-photo-frame photo-rise" data-page-reveal>
          <FactoryImage image={contactImage} loading="eager" sizes="(min-width: 1024px) 42vw, 100vw" class="profile-photo contact-photo image-cut" />
        </div>
        <p class="image-caption" data-page-reveal style="--reveal-index: 1">{content.imageCaption}</p>
        <div class="contact-facts" data-page-reveal style="--reveal-index: 2">
          <div class="contact-fact">
            <dt>Адрес</dt>
            <dd>{company.addressBg}</dd>
          </div>
          <div class="contact-fact">
            <dt>Телефон</dt>
            <dd>{company.phonePlaceholder}</dd>
          </div>
          <div class="contact-fact">
            <dt>Email</dt>
            <dd>{company.emailPlaceholder}</dd>
          </div>
        </div>
      </aside>

      <div class="profile-copy contact-form-wrap">
        <div class="profile-section-heading contact-form-heading" data-page-reveal>
          <p class="eyebrow">{content.heroLabel}</p>
          <h2 class="profile-section-title">{content.formTitle}</h2>
          <p class="body-copy">{content.formIntro}</p>
        </div>
        <ContactForm lang={lang} successPath="/bg/contact-success" />
      </div>
    </div>
  </section>
</BaseLayout>
