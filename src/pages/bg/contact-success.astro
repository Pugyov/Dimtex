---
import BaseLayout from "../../layouts/BaseLayout.astro";

const lang = "bg";
---

<BaseLayout title="Изпратено запитване | ДИМТЕКС ООД" description="Потвърждение за изпратена форма за контакт." lang={lang} noIndex>
  <section class="section-space">
    <div class="shell success-panel">
      <p class="eyebrow hero-entry">Благодарим</p>
      <h1 class="display-title hero-entry hero-entry-delay-1">Вашето запитване беше изпратено.</h1>
      <div class="rule hero-entry hero-entry-delay-2 pt-6">
        <a href="/bg/contact" class="button-primary">Обратно към контакт</a>
      </div>
    </div>
  </section>
</BaseLayout>
