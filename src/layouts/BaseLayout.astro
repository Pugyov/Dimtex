---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { company } from "../data/company";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang: "en" | "bg";
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  hideChrome?: boolean;
  noScroll?: boolean;
  noIndex?: boolean;
  preloadImages?: string[];
}

const {
  title,
  description,
  lang,
  canonical,
  ogTitle,
  ogDescription,
  hideChrome = false,
  noScroll = false,
  noIndex = false,
  preloadImages = []
} = Astro.props;
const siteUrl = "https://dimtex.bg";
const faviconPath = "/images/DimtexLogos/DimtexLogo_FaviconD.png";
const logoPath = "/images/DimtexLogos/DimtexLogo_Full.png";
const canonicalUrl = canonical ? new URL(canonical, siteUrl).toString() : new URL(Astro.url.pathname, siteUrl).toString();

const normalizePath = (path: string) => {
  if (path === "/" || path === "") {
    return "/";
  }

  return `/${path.replace(/^\/|\/$/g, "")}/`;
};

const currentPath = normalizePath(new URL(canonicalUrl).pathname);
const alternateRoutes: Record<string, { en: string; bg: string; default: string }> = {
  "/": { en: "/", bg: "/bg/", default: "/" },
  "/bg/": { en: "/", bg: "/bg/", default: "/" },
  "/about/": { en: "/about/", bg: "/bg/about/", default: "/about/" },
  "/bg/about/": { en: "/about/", bg: "/bg/about/", default: "/about/" },
  "/contact/": { en: "/contact/", bg: "/bg/contact/", default: "/contact/" },
  "/bg/contact/": { en: "/contact/", bg: "/bg/contact/", default: "/contact/" }
};
const alternates = noIndex ? undefined : alternateRoutes[currentPath];
const organizationStructuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  name: company.nameEn,
  alternateName: company.nameBg,
  url: siteUrl,
  logo: `${siteUrl}${logoPath}`,
  foundingDate: company.founded,
  email: company.emailPlaceholder,
  telephone: company.phonePlaceholder,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Aleksandar Stamboliyski 77",
    addressLocality: company.city,
    addressCountry: company.country
  },
  areaServed: company.country,
  industry: company.industryEn,
  description: `${company.nameEn} is a clothing manufacturer in ${company.city}, ${company.country}, focused on ${company.productionFocusEn.toLowerCase()}, sewing services, and subcontract production.`,
  makesOffer: company.servicesEn.map((service) => ({
    "@type": "Offer",
    itemOffered: {
      "@type": "Service",
      name: service
    }
  }))
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalUrl} />
    {alternates && (
      <>
        <link rel="alternate" hreflang="en" href={new URL(alternates.en, siteUrl).toString()} />
        <link rel="alternate" hreflang="bg" href={new URL(alternates.bg, siteUrl).toString()} />
        <link rel="alternate" hreflang="x-default" href={new URL(alternates.default, siteUrl).toString()} />
      </>
    )}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="DIMTEX LTD" />
    <meta property="og:image" content={`${siteUrl}${logoPath}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationStructuredData)} />
    {preloadImages.map((imageSrc) => <link rel="preload" as="image" href={imageSrc} fetchpriority="high" />)}
    <link rel="icon" type="image/png" sizes="448x448" href={faviconPath} />
    <link rel="apple-touch-icon" href={faviconPath} />
  </head>
  <body class:list={[noScroll ? "overflow-hidden" : ""]}>
    {!hideChrome && <Header lang={lang} pathname={Astro.url.pathname} />}
    <main>
      <slot />
    </main>
    {!hideChrome && <Footer lang={lang} />}
    <script>
      import Lenis from "lenis";

      const setupSmoothScroll = () => {
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (prefersReducedMotion || document.body.classList.contains("overflow-hidden")) {
          return null;
        }

        return new Lenis({
          anchors: true,
          autoRaf: true,
          lerp: 0.08,
          stopInertiaOnNavigate: true,
          prevent: (node) => node.closest("[data-lenis-prevent]") !== null
        });
      };

      const setupPageReveal = () => {
        const revealItems = document.querySelectorAll("[data-page-reveal]");

        if (!revealItems.length) return;

        document.documentElement.classList.add("supports-page-reveal");

        if (!("IntersectionObserver" in window)) {
          revealItems.forEach((item) => item.classList.add("is-visible"));
          return;
        }

        let revealTicking = false;
        const updateRevealItems = () => {
          revealItems.forEach((item) => {
            const rect = item.getBoundingClientRect();
            const isInRevealRange = rect.top < window.innerHeight * 0.88 && rect.bottom > window.innerHeight * 0.08;
            item.classList.toggle("is-visible", isInRevealRange);
          });
        };

        const requestRevealUpdate = () => {
          if (revealTicking) return;
          revealTicking = true;
          window.requestAnimationFrame(() => {
            updateRevealItems();
            revealTicking = false;
          });
        };

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              entry.target.classList.toggle("is-visible", entry.isIntersecting);
            });
          },
          {
            threshold: 0.22,
            rootMargin: "-8% 0px -12% 0px"
          }
        );

        revealItems.forEach((item) => revealObserver.observe(item));
        updateRevealItems();
        window.addEventListener("scroll", requestRevealUpdate, { passive: true });
        window.addEventListener("resize", requestRevealUpdate);
      };

      const setupPage = () => {
        setupSmoothScroll();
        setupPageReveal();
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupPage, { once: true });
      } else {
        setupPage();
      }
    </script>
  </body>
</html>
