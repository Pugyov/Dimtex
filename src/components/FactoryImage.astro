---
import { existsSync } from "node:fs";
import { join } from "node:path";

interface FactoryImageData {
  src: string;
  fallbackSrc: string;
  alt: string;
}

interface Props {
  image: FactoryImageData;
  class?: string;
  loading?: "eager" | "lazy";
  sizes?: string;
}

const { image, class: className = "", loading = "lazy", sizes } = Astro.props;
const publicPath = image.src.startsWith("/") ? image.src.slice(1) : image.src;
const realImageExists = existsSync(join(process.cwd(), "public", publicPath));
const resolvedSrc = realImageExists ? image.src : image.fallbackSrc;
const decoding = loading === "eager" ? "sync" : "async";
const fetchPriority = loading === "eager" ? "high" : "auto";
---

<img
  src={resolvedSrc}
  alt={image.alt}
  class:list={["factory-photo", className]}
  loading={loading}
  decoding={decoding}
  fetchpriority={fetchPriority}
  sizes={sizes}
/>
