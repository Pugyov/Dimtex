---
import { navigationItems } from "../data/navigation";
import { siteCopy } from "../data/translations";
import { company } from "../data/company";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import MobileMenu from "./react/MobileMenu";

interface Props {
  lang: "en" | "bg";
  pathname: string;
}

const { lang, pathname } = Astro.props;
const copy = siteCopy[lang];
const logoPath = "/images/DimtexLogos/DimtexLogo_Full.png";
const headerHours =
  lang === "en"
    ? "Mon - Fri, 8 AM - 5 PM"
    : "Пон - Пет, 8:00 - 17:00";

const navItems = navigationItems.map((item) => ({
  key: item.key,
  label: copy.nav[item.key],
  href: lang === "en" ? item.path : item.bgPath,
  active:
    pathname === (lang === "en" ? item.path : item.bgPath) ||
    (item.key === "home" && pathname === (lang === "en" ? "/" : "/bg"))
}));
---

<header class="sticky top-0 z-40 bg-[#2b2f28] [color:var(--text-on-dark)]">
  <div class="hidden border-b border-white/10 lg:block">
    <div class="shell flex min-h-12 items-center justify-between gap-8 text-sm [color:var(--text-on-dark-muted)]">
      <p>{lang === "en" ? "Call us" : "Тел."} : {company.phonePlaceholder}</p>
      <p>{lang === "en" ? "Open hours" : "Работно време"} : {headerHours}</p>
    </div>
  </div>

  <div class="shell grid min-h-24 grid-cols-[auto_1fr_auto] items-center gap-6 py-3">
    <a href={lang === "en" ? "/" : "/bg"} class="site-logo-link" aria-label={copy.brand}>
      <img src={logoPath} alt={copy.brand} class="site-logo" width="1536" height="1024" />
    </a>

    <nav class="hidden items-center justify-center gap-10 lg:flex" aria-label={lang === "en" ? "Primary navigation" : "Основна навигация"}>
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-[0.82rem] uppercase tracking-[0.16em] [color:var(--text-on-dark-subtle)] hover:[color:var(--text-on-dark)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent",
            item.active ? "text-[#c8843e]" : ""
          ]}
          aria-current={item.active ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center justify-end lg:flex">
      <LanguageSwitcher lang={lang} pathname={pathname} />
    </div>

    <div class="col-start-3 lg:hidden">
      <MobileMenu client:load lang={lang} pathname={pathname} />
    </div>
  </div>
</header>
