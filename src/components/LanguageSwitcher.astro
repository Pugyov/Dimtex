---
import { siteCopy } from "../data/translations";

interface Props {
  lang: "en" | "bg";
  pathname: string;
}

const { lang, pathname } = Astro.props;
const copy = siteCopy[lang];

const trimmedPath = pathname.replace(/\/$/, "") || "/";
const alternatePath =
  lang === "en"
    ? trimmedPath === "/"
      ? "/bg"
      : `/bg${trimmedPath}`
    : trimmedPath === "/bg"
      ? "/"
      : trimmedPath.replace(/^\/bg/, "") || "/";
---

<button
  type="button"
  data-lang-target={alternatePath}
  class="text-sm text-[rgba(17,17,17,0.56)] underline-offset-4 hover:text-[#111111] hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
  aria-label={lang === "en" ? "Switch language to Bulgarian" : "Смени езика на английски"}
>
  <span>{copy.otherLocaleName}</span>
</button>

<script>
  const switches = document.querySelectorAll("[data-lang-target]");

  for (const entry of switches) {
    entry.addEventListener("click", () => {
      const target = entry.getAttribute("data-lang-target");
      if (target) {
        window.location.assign(target);
      }
    });
  }
</script>
