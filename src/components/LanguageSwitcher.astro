---
import { siteCopy } from "../data/translations";

interface Props {
  lang: "en" | "bg";
  pathname: string;
}

const { lang, pathname } = Astro.props;
const copy = siteCopy[lang];

const trimmedPath = pathname.replace(/\/$/, "") || "/";
const alternatePath =
  lang === "en"
    ? trimmedPath === "/"
      ? "/bg"
      : `/bg${trimmedPath}`
    : trimmedPath === "/bg"
      ? "/"
      : trimmedPath.replace(/^\/bg/, "") || "/";
---

<a
  href={alternatePath}
  class="text-sm [color:var(--text-on-dark-subtle)] underline-offset-4 hover:[color:var(--text-on-dark)] hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
  aria-label={lang === "en" ? "Switch language to Bulgarian" : "Смени езика на английски"}
>
  <span>{copy.otherLocaleName}</span>
</a>
