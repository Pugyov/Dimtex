---
type Item = {
  title: string;
};

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<section class="section-space pt-8 sm:pt-12 lg:pt-16">
  <div class="shell">
    <div class="rule pt-6 sm:pt-8">
      <div data-scroll-sequence class="sequence-wrap">
        {items.map((item) => (
          <article class="sequence-item" data-sequence-step>
            <h2 class="sequence-word">{item.title}</h2>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const sequences = document.querySelectorAll("[data-scroll-sequence]");

  for (const sequence of sequences) {
    const steps = Array.from(sequence.querySelectorAll("[data-sequence-step]"));
    if (!steps.length) continue;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle("is-visible", entry.isIntersecting);
        });
      },
      {
        threshold: 0.35,
        rootMargin: "-10% 0px -10% 0px"
      }
    );

    steps.forEach((step) => observer.observe(step));
  }
</script>
